import curses
import random

# Initialize screen
screen = curses.initscr()
curses.curs_set(0)

height, width = screen.getmaxyx()

game_win = curses.newwin(height, width, 0, 0)
game_win.keypad(True)
game_win.timeout(100)

# Initial snake
snake = [
    [height // 2, width // 4],
    [height // 2, width // 4 - 1],
    [height // 2, width // 4 - 2]
]

food = [height // 2, width // 2]
game_win.addch(food[0], food[1], '*')

key = curses.KEY_RIGHT
score = 0

while True:
    next_key = game_win.getch()
    if next_key != -1:
        key = next_key

    head = snake[0].copy()

    if key == curses.KEY_RIGHT:
        head[1] += 1
    elif key == curses.KEY_LEFT:
        head[1] -= 1
    elif key == curses.KEY_UP:
        head[0] -= 1
    elif key == curses.KEY_DOWN:
        head[0] += 1

    # Collision with wall
    if (
        head[0] <= 0 or
        head[0] >= height - 1 or
        head[1] <= 0 or
        head[1] >= width - 1
    ):
        break

    # Collision with itself
    if head in snake:
        break

    snake.insert(0, head)

    if head == food:
        score += 1
        while True:
            new_food = [
                random.randint(1, height - 2),
                random.randint(1, width - 2)
            ]
            if new_food not in snake:
                food = new_food
                break

        game_win.addch(food[0], food[1], '*')
    else:
        tail = snake.pop()
        game_win.addch(tail[0], tail[1], ' ')

    game_win.addch(head[0], head[1], '#')

curses.endwin()
print("Game Over!")
print("Score:", score)

